{
  "name": "transition-lit",
  "description": "Rudimentary animation/transition library written for React applications",
  "version": "1.0.0",
  "license": "MIT",
  "author": "Joel Voß <joel.voss@twt.de>",
  "homepage": "https://github.com/joelvoss/transition-lit",
  "bugs": {
    "url": "https://github.com/joelvoss/transition-lit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joelvoss/transition-lit.git"
  },
  "main": "dist/cjs/index.cjs.js",
  "module": "dist/esm/index.es.js",
  "typings": "dist/types/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "jvdx build rollup 'src/index.tsx' -f cjs,esm -c",
    "lint": "jvdx lint",
    "format": "jvdx format",
    "test": "jvdx test",
    "validate": "npm run format && npm run lint && npm run test",
    "clean": "jvdx clean dist && (cd examples/basic && yarn clean); (cd examples/transition-group && yarn clean); (cd examples/css-transition && yarn clean);",
    "prepublish": "npm run build"
  },
  "dependencies": {
    "@babel/runtime": "7.9.6",
    "dom-helpers": "5.1.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "5.5.0",
    "@testing-library/react": "10.0.4",
    "@types/jest": "25.2.1",
    "@types/react": "16.9.34",
    "@types/react-dom": "16.9.7",
    "jvdx": "1.2.0",
    "react": "16.13.0",
    "react-dom": "16.13.0"
  },
  "peerDependencies": {
    "react": "^16.8.0",
    "react-dom": "^16.8.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "jvdx pre-commit"
    }
  }
}
